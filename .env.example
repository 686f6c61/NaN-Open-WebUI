# ============================================================
#  nan-open-webui  -  configuracion
#  Copia este fichero a  .env   y rellena tus valores.
#  NUNCA subas tu .env a git ni lo compartas: contiene tu API key.
# ============================================================

# (OBLIGATORIO) Tu API key de NaN.  Consiguela en https://nan.builders
NAN_API_KEY=sk-pon-aqui-tu-api-key

# (RECOMENDADO) Clave secreta para firmar las sesiones de la web.
#   Genera una unica con:   openssl rand -hex 32
#   (./setup.sh la genera por ti automaticamente)
WEBUI_SECRET_KEY=

# (OPCIONAL) Puerto local donde se publica la web. Por defecto 3000.
WEBUI_PORT=3000

# (OPCIONAL) Nombre que aparece en la interfaz.
WEBUI_NAME=NaN Chat

# (OPCIONAL) Permitir que otros se registren (true) o cerrar el registro (false).
#   Deja 'true' la primera vez para crear tu cuenta admin; luego puedes ponerlo en 'false'.
ENABLE_SIGNUP=true

# (OPCIONAL) Endpoint OpenAI-compatible. Cambialo solo si usas otro (p. ej. Helmcode).
OPENAI_API_BASE_URL=https://api.nan.builders/v1

# (OPCIONAL) Busqueda web. Viene activada y no necesita ninguna API key (usa el
#   buscador propio SearXNG que ya esta incluido). Ponlo en 'false' para desactivarla.
ENABLE_WEB_SEARCH=true

# (OPCIONAL) Voz con la que el chat lee las respuestas (modelo 'kokoro' de NaN).
#   Otras: af_bella, af_nicole, am_adam, bf_emma...  El dictado por voz (entrada)
#   usa un whisper local del contenedor y no necesita configurarse.
AUDIO_TTS_VOICE=af_sky

# (OPCIONAL) Modelo de NaN para las tareas internas (titulos, etiquetas, autocompletado).
#   Conviene uno rapido y barato.
TASK_MODEL_EXTERNAL=deepseek-v4-flash
